# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=1                         # keep 1 when loading large GPU models

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Paths ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./outputs
MODEL_DIR=./models/checkpoints
TEMP_DIR=./outputs/intermediates

# ── 2D VTON (OOTDiffusion) ────────────────────────────────────────────────────
# Clone from: https://github.com/levihsu/OOTDiffusion
VTON_MODEL_PATH=./models/checkpoints/ootd
VTON_BACKEND=ootdiffusion            # ootdiffusion | catvton

# ── 3D Reconstruction (PIFuHD) ────────────────────────────────────────────────
# Clone from: https://github.com/facebookresearch/pifuhd
PIFUHD_REPO_PATH=./models/pifuhd
PIFUHD_CHECKPOINT=./models/checkpoints/pifuhd/pifuhd_final.pt
RECONSTRUCTION_BACKEND=pifuhd        # pifuhd | geneman

# ── GPU ───────────────────────────────────────────────────────────────────────
CUDA_DEVICE=0
HALF_PRECISION=true                  # fp16 inference to save VRAM

# ── Image Settings ────────────────────────────────────────────────────────────
TARGET_WIDTH=512
TARGET_HEIGHT=768
REMBG_MODEL=u2net_human_seg          # u2net | u2net_human_seg | isnet-general-use
