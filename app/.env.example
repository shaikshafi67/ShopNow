# ============================================
# Razorpay Configuration
# ============================================
# Get your keys from: https://dashboard.razorpay.com/app/keys
#
# For TESTING: Use test keys (starts with rzp_test_)
# For PRODUCTION: Use live keys (starts with rzp_live_)
#
# Steps:
# 1. Go to https://dashboard.razorpay.com/signup
# 2. Sign up / Login
# 3. Go to Settings → API Keys → Generate Key
# 4. Copy Key ID and Key Secret below
# 5. Rename this file to .env

RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Server port for the payment backend
PORT=3001

# ============================================
# EmailJS Configuration (OTP Email Sending)
# ============================================
# Sign up free at https://www.emailjs.com
# Steps:
# 1. Create account → Email Services → Add Gmail/Outlook
# 2. Email Templates → Create Template
#    Subject: Your ShopNow verification code
#    Body: Hi {{to_name}}, your OTP is: {{otp}}
#    To Email: {{to_email}}
# 3. Copy Service ID, Template ID, and Public Key below

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
